# ┌──────────────────────────────────────────────────┐
# │  THIS IS EXAMPLE OF .env FILE.                   │
# │  REPLACE PLACEHOLDER VALUES WITH YOUR REAL ONES. │
# └──────────────────────────────────────────────────┘  

# APP SETTINGS
ENVIRONMENT=development
APP_PORT=8000

# DATABASE
POSTGRES_USER=my_postgres_user
POSTGRES_PASSWORD=my_postgres_password
POSTGRES_DB=my_postgres_db
POSTGRES_HOST=my_postgres_host
POSTGRES_PORT=5432

# AUTH
JWT_ACCESS_SECRET=my_jwt_access_secret_key_minimum_32_characters_long
JWT_REFRESH_SECRET=my_jwt_refresh_secret_key_minimum_32_characters_long